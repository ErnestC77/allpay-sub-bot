# --- Telegram ---
BOT_TOKEN=123456:PUT_YOUR_BOT_TOKEN_HERE

# Список Telegram ID администраторов через запятую
ADMIN_IDS=910256253

# Контакт поддержки (username или ссылка), показывается в разделе «Поддержка»
SUPPORT_CONTACT=@your_admin_username

# --- AllPay ---
# Данные из личного кабинета AllPay: Settings > Integrations
ALLPAY_LOGIN=your_allpay_login
ALLPAY_KEY=your_allpay_api_key

# Базовый публичный URL, на который AllPay шлёт webhook и куда возвращает пользователя.
# Локально — туннель (ngrok/cloudflared), в проде — домен сервиса. Без завершающего слэша.
WEBHOOK_BASE_URL=https://example.com

# --- Сервер / БД ---
# Порт aiohttp-сервера (для webhook). На Render берётся из окружения автоматически.
PORT=8080

# PostgreSQL 16. Формат: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# (если провайдер даёт URL вида postgresql://... — драйвер будет заменён на asyncpg автоматически)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/subbot

# Валюта по умолчанию (ILS / USD / EUR — поддерживаются AllPay)
DEFAULT_CURRENCY=ILS

# Как часто (в секундах) проверять подписки для уведомлений об окончании.
# 3600 = раз в час. Дедупликация гарантирует один показ каждого порога.
REMINDER_CHECK_INTERVAL=3600
